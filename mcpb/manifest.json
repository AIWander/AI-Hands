{
  "$schema": "https://raw.githubusercontent.com/anthropics/mcpb/main/schemas/mcpb-manifest-v0.4.schema.json",
  "manifest_version": "0.4",
  "name": "hands",
  "display_name": "CPC Hands",
  "version": "1.3.5",
  "description": "Browser automation, Windows UIA, OCR, and computer vision for Claude",
  "long_description": "CPC Hands provides Playwright-based browser automation, Windows UI Automation (UIA) for native app control, OCR text extraction, and computer vision capabilities. It enables Claude to interact with any application or website on Windows.",
  "author": {
    "name": "AIWander",
    "url": "https://github.com/AIWander/hands"
  },
  "homepage": "https://github.com/AIWander/hands",
  "repository": {
    "type": "git",
    "url": "https://github.com/AIWander/hands"
  },
  "license": "MIT",
  "keywords": ["mcp", "claude", "cpc", "browser", "automation", "uia", "ocr", "vision"],
  "server": {
    "type": "binary",
    "entry_point": "server/hands.exe",
    "mcp_config": {
      "command": "${__dirname}/server/hands.exe",
      "args": [],
      "env": {}
    }
  },
  "compatibility": {
    "claude_desktop": ">=0.10.0",
    "platforms": ["win32"]
  }
}
